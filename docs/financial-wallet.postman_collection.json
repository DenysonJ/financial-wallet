{
  "info": {
    "_postman_id": "f1a2c9d0-0000-4a1a-9b7e-financial-wallet",
    "name": "Financial Wallet API",
    "description": "Postman collection covering all routes currently implemented in the financial-wallet microservice. Routes are grouped by domain (Health, Auth, Users, Roles, Accounts, Statements). Uses {{base_url}}, service key headers, JWT, randomized email/name, and post-response scripts to propagate IDs/tokens across requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080", "type": "string" },
    { "key": "service_name", "value": "postman", "type": "string" },
    { "key": "service_key", "value": "change-me", "type": "string" },
    { "key": "access_token", "value": "", "type": "string" },
    { "key": "refresh_token", "value": "", "type": "string" },
    { "key": "user_id", "value": "", "type": "string" },
    { "key": "role_id", "value": "", "type": "string" },
    { "key": "account_id", "value": "", "type": "string" },
    { "key": "statement_id", "value": "", "type": "string" },
    { "key": "user_email", "value": "", "type": "string" },
    { "key": "user_password", "value": "Str0ngP@ssw0rd!", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Generates a fresh random email/name per request, stored in collection variables.",
          "const rand = Math.random().toString(36).slice(2, 10);",
          "const firstNames = ['Alice','Bob','Carol','Diego','Elena','Felipe','Gabi','Hugo','Isa','Joao'];",
          "const lastNames  = ['Silva','Souza','Costa','Pereira','Almeida','Lima','Rocha','Martins'];",
          "const fn = firstNames[Math.floor(Math.random()*firstNames.length)];",
          "const ln = lastNames[Math.floor(Math.random()*lastNames.length)];",
          "pm.variables.set('random_name', `${fn} ${ln}`);",
          "pm.variables.set('random_email', `${fn.toLowerCase()}.${ln.toLowerCase()}.${rand}@example.com`);",
          "pm.variables.set('idempotency_key', pm.variables.replaceIn('{{$guid}}'));"
        ]
      }
    }
  ],
