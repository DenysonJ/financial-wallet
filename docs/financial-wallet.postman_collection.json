    {
      "name": "Statements",
      "item": [
        {
          "name": "Create Statement",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const data = json.data || json;",
                  "if (data && data.id) {",
                  "  pm.collectionVariables.set('statement_id', data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Service-Name", "value": "{{service_name}}" },
              { "key": "Service-Key", "value": "{{service_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"credit\",\n  \"amount\": 12500,\n  \"description\": \"Salary deposit for {{random_name}}\",\n  \"posted_at\": \"{{$isoTimestamp}}\",\n  \"category_id\": \"{{category_id}}\",\n  \"tag_ids\": [\"{{tag_id}}\"]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "category_id and tag_ids are optional. Category type must match statement type. tag_ids deduplicated; max 10.",
            "url": {
              "raw": "{{base_url}}/accounts/{{account_id}}/statements",
              "host": ["{{base_url}}"],
              "path": ["accounts", "{{account_id}}", "statements"]
            }
          }
        },
        {
          "name": "Import Statements (OFX)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Service-Name", "value": "{{service_name}}" },
              { "key": "Service-Key", "value": "{{service_key}}" },
              { "key": "Idempotency-Key", "value": "{{idempotency_key}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": [],
                  "description": "OFX file (max 5MB). Replace with a local .ofx file in Postman before sending."
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/accounts/{{account_id}}/statements/import",
              "host": ["{{base_url}}"],
              "path": ["accounts", "{{account_id}}", "statements", "import"]
            }
          }
        },
        {
          "name": "List Statements",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Service-Name", "value": "{{service_name}}" },
              { "key": "Service-Key", "value": "{{service_key}}" }
            ],
            "url": {
              "raw": "{{base_url}}/accounts/{{account_id}}/statements?page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["accounts", "{{account_id}}", "statements"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "type", "value": "", "disabled": true },
                { "key": "date_from", "value": "", "disabled": true },
                { "key": "date_to", "value": "", "disabled": true },
                { "key": "category_id", "value": "{{category_id}}", "disabled": true, "description": "Filter by category (REQ-13)" },
                { "key": "tag_ids", "value": "{{tag_id}}", "disabled": true, "description": "Filter by tag — repeat the param for multiple tags (REQ-13)" },
                { "key": "cursor", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Statement by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Service-Name", "value": "{{service_name}}" },
              { "key": "Service-Key", "value": "{{service_key}}" }
            ],
            "url": {
              "raw": "{{base_url}}/accounts/{{account_id}}/statements/{{statement_id}}",
              "host": ["{{base_url}}"],
              "path": ["accounts", "{{account_id}}", "statements", "{{statement_id}}"]
            }
          }
        },
        {
          "name": "Reverse Statement",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Service-Name", "value": "{{service_name}}" },
              { "key": "Service-Key", "value": "{{service_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Reversal requested via Postman\"\n}"
            },
            "description": "Reversal auto-applies the system default 'Estorno' category matching the reversed type. Tags are NOT inherited from the original.",
            "url": {
              "raw": "{{base_url}}/accounts/{{account_id}}/statements/{{statement_id}}/reverse",
              "host": ["{{base_url}}"],
              "path": ["accounts", "{{account_id}}", "statements", "{{statement_id}}", "reverse"]
            }
          }
        },
        {
          "name": "Update Statement Category (set/swap/clear)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Service-Name", "value": "{{service_name}}" },
              { "key": "Service-Key", "value": "{{service_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"category_id\": \"{{category_id}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "REQ-11: Set, swap, or clear (send {\"category_id\": null}) the category. Category type must match statement type. NEVER touches amount/type/balance_after.",
            "url": {
              "raw": "{{base_url}}/statements/{{statement_id}}/category",
              "host": ["{{base_url}}"],
              "path": ["statements", "{{statement_id}}", "category"]
            }
          }
        },
        {
          "name": "Replace Statement Tags",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Service-Name", "value": "{{service_name}}" },
              { "key": "Service-Key", "value": "{{service_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tag_ids\": [\"{{tag_id}}\", \"{{tag_id_2}}\"]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "REQ-10: Replaces the entire tag set. Empty array clears all tags. Deduplicated; max 10. NEVER touches accounting fields.",
            "url": {
              "raw": "{{base_url}}/statements/{{statement_id}}/tags",
              "host": ["{{base_url}}"],
              "path": ["statements", "{{statement_id}}", "tags"]
            }
          }
        }
